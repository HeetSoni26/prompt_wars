# Frontend Environment Variables

# Firebase Web Config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Backend API URL (only set in production; dev uses Vite proxy)
# VITE_API_URL=https://careerpilot-api-xxxx-uc.a.run.app/api

# Optional: Use Firebase emulators for local development
# VITE_USE_FIREBASE_EMULATOR=true
